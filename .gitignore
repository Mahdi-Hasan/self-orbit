# ---- .NET ----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
*.cover
*.pyo

# ---- Node.js / Next.js ----
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Docker ----
docker-compose.override.yml

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Environment ----
.env
.env.local
.env.*.local
*.env

# ---- Protobuf generated ----
*_pb2.py
*_pb2_grpc.py
*_pb2.pyi
